{
  "name": "conversor-zpl-pdf",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter zpl-pdf-server dev\" \"pnpm --filter zpl-pdf-client dev\"",
    "start": "pnpm --filter zpl-pdf-server start",
    "build": "pnpm --filter zpl-pdf-client build",
    "install:all": "pnpm install"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
